# =============================================================
# Backend environment variables
# Copy this file to `.env` (same directory) and fill in values.
# NEVER commit the real `.env` file - it is git-ignored.
# Docker Compose reads `.env` automatically.
# For running Spring Boot locally (mvnw spring-boot:run), set these
# as OS environment variables or in your IDE run configuration.
# =============================================================

# --- Database (local dev default: postgres/postgres) ---
DB_USERNAME=postgres
DB_PASSWORD=

# --- Database - cloud deployment with Neon (set these on Render, not locally) ---
# Neon has NO "API key" for the app - it gives a normal Postgres connection string:
#   postgresql://USER:PASSWORD@ep-xxx.ap-southeast-1.aws.neon.tech/DBNAME?sslmode=require
# Split it into these variables (Neon requires SSL -> DB_SSLMODE=require):
# DB_HOST=ep-xxx.ap-southeast-1.aws.neon.tech
# DB_PORT=5432
# DB_NAME=
# DB_SSLMODE=require

# --- Redis - cloud deployment with Upstash (set these on Render, not locally) ---
# Upstash (upstash.com) -> create Redis database -> copy endpoint + password.
# Upstash requires TLS -> REDIS_SSL=true
# REDIS_HOST=xxx.upstash.io
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_SSL=true

# --- JWT (required in prod; generate 64+ random chars, e.g. `openssl rand -base64 64`) ---
JWT_SECRET=

# --- Cloudinary (Dashboard -> Settings -> Access Keys) ---
CLOUDINARY_CLOUD_NAME=dxxdhz5f5
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- PayPal sandbox (developer.paypal.com -> Apps & Credentials) ---
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# --- Email: Brevo HTTP API - primary (brevo.com -> Settings -> SMTP & API -> API Keys) ---
# Works on Render (SMTP ports are blocked there). Free: 300 emails/day.
BREVO_API_KEY=

# --- Email: Gmail SMTP - fallback, only works local/VPS (NOT on Render) ---
# MAIL_PASSWORD is a Gmail App Password (myaccount.google.com -> Security -> App passwords)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# --- AI - DeepSeek only (platform.deepseek.com -> API Keys) ---
DEEPSEEK_API_KEY=

# --- CORS (comma-separated frontend origins) ---
CORS_ORIGINS=http://localhost:3000

# =============================================================
# VN payment gateways - Phase 2.4 (NOT wired into code yet).
# Uncomment when the integration lands. Register sandbox accounts:
# =============================================================

# --- VNPay sandbox (register: sandbox.vnpayment.vn/devreg) ---
# VNPAY_TMN_CODE=
# VNPAY_HASH_SECRET=
# VNPAY_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
# VNPAY_RETURN_URL=http://localhost:3000/payment/vnpay-return

# --- MoMo test environment (no registration needed - public test credentials
#     are published in the docs at developers.momo.vn; grab the latest values) ---
# MOMO_PARTNER_CODE=
# MOMO_ACCESS_KEY=
# MOMO_SECRET_KEY=
# MOMO_ENDPOINT=https://test-payment.momo.vn

# --- PayOS - VietQR bank transfer (register: my.payos.vn) ---
# PAYOS_CLIENT_ID=
# PAYOS_API_KEY=
# PAYOS_CHECKSUM_KEY=
